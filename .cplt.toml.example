# Optional per-repo cplt overrides (default sandbox is Ceiku/cplt). Copy to .cplt.toml and adjust.
#
# Broker UDS access is configured automatically by ./bin/agent-run via
# --allow-write on the socket directory and socket path. You only need this file for
# extra project-specific permissions.

[deny]
# Tighten beyond cplt defaults (optional)
# paths = ["~/extra-secrets"]

[propose]
# Permissions that require: cplt trust accept --all
# subro passes --agent pi|opencode|shell and harness env vars automatically.
# allow_localhost_any = true   # pi / OpenCode TUI and loopback servers
# allow_jvm_attach = true      # MockK / Mockito inline

[propose.allow]
# localhost = [3000, 8080]
# ports = [5432]
