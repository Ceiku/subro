#!/usr/bin/env bash
set -euo pipefail

ROOT="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
BROKER_DIR="${ROOT}/broker"
VENV_DIR="${BROKER_DIR}/.venv"
PID_DIR="${ROOT}/.broker"
PID_FILE="${PID_DIR}/broker.pid"
LOG_FILE="${PID_DIR}/log.txt"

mkdir -p "$PID_DIR"

default_sock() {
  local uname_s
  uname_s="$(uname -s)"
  case "$uname_s" in
    Darwin)
      echo "${HOME}/Library/Application Support/agent-broker/agent-broker.sock"
      ;;
    Linux)
      local rt
      rt="${XDG_RUNTIME_DIR:-/tmp}"
      echo "${rt}/agent-broker/agent-broker.sock"
      ;;
    *)
      echo "/tmp/agent-broker/agent-broker.sock"
      ;;
  esac
}

default_env_file() {
  echo "${HOME}/.config/agent-broker/env"
}

load_env_file() {
  local env_file
  env_file="${BROKER_ENV_FILE:-$(default_env_file)}"
  if [[ -f "$env_file" ]]; then
    set -a
    # shellcheck disable=SC1090
    source "$env_file"
    set +a
  fi
}

ensure_sock_dir() {
  local sock
  sock="${BROKER_SOCK:-$(default_sock)}"
  mkdir -p "$(dirname "$sock")"
}

ensure_venv() {
  if [[ ! -d "$VENV_DIR" ]]; then
    python3 -m venv "$VENV_DIR"
  fi
  "${VENV_DIR}/bin/python" -m pip install --upgrade pip >/dev/null
  "${VENV_DIR}/bin/python" -m pip install -r "${BROKER_DIR}/requirements.txt" >/dev/null
}

is_running() {
  if [[ -f "$PID_FILE" ]]; then
    local pid
    pid="$(cat "$PID_FILE")"
    if kill -0 "$pid" 2>/dev/null; then
      return 0
    fi
  fi
  return 1
}

cmd="${1:-}"

case "$cmd" in
  start)
    if is_running; then
      echo "Broker already running (pid $(cat "$PID_FILE"))."
      exit 0
    fi

    load_env_file
    ensure_sock_dir
    sock="${BROKER_SOCK:-$(default_sock)}"
    if [[ -S "$sock" ]]; then
      rm -f "$sock"
    fi
    ensure_venv

    # shellcheck disable=SC2091
    nohup "${VENV_DIR}/bin/python" "${BROKER_DIR}/main.py" >>"$LOG_FILE" 2>&1 &
    echo "$!" >"$PID_FILE"
    echo "Broker started (pid $!). Logs: $LOG_FILE"
    ;;

  stop)
    if ! [[ -f "$PID_FILE" ]]; then
      echo "Broker not running (no pid file)."
      exit 0
    fi
    pid="$(cat "$PID_FILE")"
    if kill -0 "$pid" 2>/dev/null; then
      kill "$pid"
      echo "Sent SIGTERM to broker (pid $pid)."
    else
      echo "Stale pid file (pid $pid not running)."
    fi
    rm -f "$PID_FILE"
    ;;

  status)
    if is_running; then
      echo "Broker running (pid $(cat "$PID_FILE"))."
      exit 0
    fi
    echo "Broker not running."
    exit 1
    ;;

  logs)
    if [[ -f "$LOG_FILE" ]]; then
      echo "Logs at: $LOG_FILE"
      exec /usr/bin/tail -n 200 "$LOG_FILE"
    fi
    echo "No logs found at: $LOG_FILE"
    exit 1
    ;;

  *)
    echo "Usage: $0 {start|stop|status|logs}"
    echo
    echo "Environment:"
    echo "  BROKER_ENV_FILE: path to env file (default: $(default_env_file))"
    echo "  BROKER_SOCK: socket path (default: $(default_sock))"
    exit 2
    ;;
esac

