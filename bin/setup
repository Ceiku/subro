#!/usr/bin/env bash
set -euo pipefail

ROOT="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
# shellcheck source=bin/_lib.sh
source "${ROOT}/bin/_lib.sh"

default_sock() {
  local uname_s
  uname_s="$(uname -s)"
  case "$uname_s" in
    Darwin)
      echo "${HOME}/Library/Application Support/agent-broker/agent-broker.sock"
      ;;
    Linux)
      local rt
      rt="${XDG_RUNTIME_DIR:-/tmp}"
      echo "${rt}/agent-broker/agent-broker.sock"
      ;;
    *)
      echo "/tmp/agent-broker/agent-broker.sock"
      ;;
  esac
}

subro_setup_check() {
  subro_load_broker_env
  local sock="${BROKER_SOCK:-$(default_sock)}"
  local env_file="${BROKER_ENV_FILE:-${HOME}/.config/agent-broker/env}"
  local cwd
  cwd="$(pwd)"

  echo "== subro setup --check =="
  echo "  version:     $(subro_version "$ROOT")"
  echo "  repo:        $ROOT"
  echo "  cwd:         $cwd"
  echo "  broker env:  ${env_file}"
  if [[ -f "$env_file" ]]; then
    echo "  env file:    present ($(stat -f '%Sm' -t '%Y-%m-%d' "$env_file" 2>/dev/null || stat -c '%y' "$env_file" 2>/dev/null | cut -d' ' -f1))"
  else
    echo "  env file:    missing (run ./bin/setup)"
  fi
  echo "  socket:      $sock"
  if "$ROOT/bin/broker-daemon" status >/dev/null 2>&1; then
    echo "  broker:      running"
  else
    echo "  broker:      not running (on-demand via ./bin/agent or ./bin/doctor)"
  fi
  echo "  sandbox:     ${SUBRO_SANDBOX:-cplt} (default: cplt)"
  if [[ "$(subro_sandbox_backend)" == "cplt" ]] && subro_cplt_available; then
    echo "  cplt:        $(subro_cplt_bin)"
  elif [[ "$(subro_sandbox_backend)" == "cplt" ]]; then
    echo "  cplt:        not found (will fall back to native)"
  fi
  echo
  echo "Broker roots:"
  subro_validate_broker_roots warn "$cwd" | sed 's/^/  /' || true
  echo
  echo "Smoke tests (no LLM): ./bin/doctor  or  ./bin/agent-run bash -lc 'entur-departures jernbanetorget 1'"
  if command -v pi >/dev/null 2>&1; then
    echo "  pi:          ./bin/agent-run pi --help  |  ./bin/agent-run pi list"
  fi
}

if [[ "${1:-}" == "--check" ]]; then
  subro_setup_check
  exit 0
fi

BROKER_ENV_FILE="${BROKER_ENV_FILE:-${HOME}/.config/agent-broker/env}"
BROKER_SOCK="${BROKER_SOCK:-$(default_sock)}"

mkdir -p "$(dirname "$BROKER_ENV_FILE")"
mkdir -p "$(dirname "$BROKER_SOCK")"

if [[ ! -f "$BROKER_ENV_FILE" ]]; then
  TOKEN="$(python3 -c 'import secrets; print(secrets.token_hex(24))' 2>/dev/null || openssl rand -hex 24)"
  cat >"$BROKER_ENV_FILE" <<EOF
# Broker-only environment. Keep this file private (chmod 600).
BROKER_SOCKET_TOKEN=${TOKEN}

# Restrict what workdirs the broker will execute inside (required):
BROKER_ALLOWED_ROOTS="${HOME}/dev,${HOME}/work"

# Secrets for broker-mediated curl — reference as $VAR_NAME in sandbox curl args:
# STRIPE_API_TOKEN=sk_live_...
# GIT_TOKEN=ghp_...
# PROD_API_KEY=...

# Optional: override socket path:
# BROKER_SOCK="$(default_sock)"

# Optional: Entur showcase skill client name (public API):
# ENTUR_CLIENT_NAME=subro-yourname

# Optional: audit log path (default ~/.config/agent-broker/audit.jsonl):
# BROKER_AUDIT_LOG=${HOME}/.config/agent-broker/audit.jsonl

# Sandbox backend: cplt (default) or native — see docs/cplt.md
# SUBRO_SANDBOX=native   # opt out of Ceiku/cplt
EOF
  chmod 600 "$BROKER_ENV_FILE" || true
  echo "Created: $BROKER_ENV_FILE (with BROKER_SOCKET_TOKEN)"
else
  echo "Exists:  $BROKER_ENV_FILE"
  if ! grep -q '^BROKER_SOCKET_TOKEN=' "$BROKER_ENV_FILE" 2>/dev/null; then
    TOKEN="$(python3 -c 'import secrets; print(secrets.token_hex(24))' 2>/dev/null || openssl rand -hex 24)"
    printf '\nBROKER_SOCKET_TOKEN=%s\n' "$TOKEN" >>"$BROKER_ENV_FILE"
    echo "Appended BROKER_SOCKET_TOKEN to existing env file"
  fi
  echo "No changes (re-run with --check to see version and status after git pull)"
fi

chmod +x "${ROOT}/bin"/{agent,agent-run,broker-daemon,broker-stdio,install-interceptors,doctor,skill-init,skills-sync,apm} 2>/dev/null || true
chmod +x "${ROOT}/interceptors"/{_broker_call.py,mvn,curl,entur-departures} 2>/dev/null || true

subro_load_broker_env
echo
echo "Broker roots check:"
subro_validate_broker_roots warn "$(pwd)" | sed 's/^/  /' || true

if [[ "$(uname -s)" == "Linux" ]]; then
  echo
  echo "Linux Landlock:"
  if landlock_line="$(subro_landlock_status "$ROOT" 2>&1)"; then
    echo "  OK: $landlock_line"
  else
    echo "  WARN: $landlock_line"
    echo "  Build: ./bin/build-landlock-restrict"
  fi
fi

echo
echo "Next steps:"
echo "1) Edit broker env file: $BROKER_ENV_FILE"
echo "   Set BROKER_ALLOWED_ROOTS to directories you develop in (must include project cwd)."
echo "2) Verify: ./bin/doctor          # auto-starts broker; safe before first ./bin/agent"
echo "3) Status after upgrades: ./bin/setup --check"
echo "4) Sync harness skills:"
echo "     ./bin/skills-sync --global-pi        # ~/.pi/agent/settings.json"
echo "     ./bin/skills-sync --global-opencode  # ~/.config/opencode/skills/"
echo "5) Run sandboxed agent: ./bin/agent pi | ./bin/agent opencode"
echo
echo "6) Install Ceiku/cplt (default sandbox — see docs/cplt.md):"
echo "     curl -fsSL https://raw.githubusercontent.com/Ceiku/cplt/main/install.sh | bash"
echo "     cplt trust accept --all"
if subro_cplt_available; then
  echo "  cplt: installed at $(subro_cplt_bin) ($(cplt --version 2>/dev/null || echo unknown))"
else
  echo "  cplt: not installed (subro falls back to native Seatbelt/Landlock)"
fi
echo "   Opt out: set SUBRO_SANDBOX=native in $BROKER_ENV_FILE"
