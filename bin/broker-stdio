#!/usr/bin/env bash
set -euo pipefail
ROOT="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
BROKER_ENV_FILE="${BROKER_ENV_FILE:-${HOME}/.config/agent-broker/env}"
if [[ -f "$BROKER_ENV_FILE" ]]; then
  set -a
  # shellcheck disable=SC1090
  source "$BROKER_ENV_FILE"
  set +a
fi
VENV="${ROOT}/broker/.venv"
if [[ ! -d "$VENV" ]]; then
  python3 -m venv "$VENV"
  "$VENV/bin/pip" install -r "${ROOT}/broker/requirements.txt" >/dev/null
fi
exec "${VENV}/bin/python" "${ROOT}/broker/stdio_main.py" "$@"
