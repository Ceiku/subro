#!/usr/bin/env bash
set -euo pipefail

ROOT="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
TARGET="${ROOT}/.agent-path"

mkdir -p "$TARGET"

ln -sf "${ROOT}/interceptors/mvn" "${TARGET}/mvn"
ln -sf "${ROOT}/interceptors/curl" "${TARGET}/curl"
ln -sf "${ROOT}/interceptors/entur-departures" "${TARGET}/entur-departures"
ln -sf "${ROOT}/interceptors/register-skill" "${TARGET}/register-skill"

echo "Installed interceptor symlinks into: $TARGET"
echo "You can prepend it to PATH, or rely on bin/agent-run which already prefers ./interceptors."

