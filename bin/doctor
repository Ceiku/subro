#!/usr/bin/env bash
set -euo pipefail

ROOT="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
# shellcheck source=bin/_lib.sh
source "$ROOT/bin/_lib.sh"

FAIL=0

ok() { echo "  OK: $*"; }
warn() { echo "  WARN: $*"; }
bad() { echo "  FAIL: $*"; FAIL=1; }

subro_load_broker_env
SOCK="${BROKER_SOCK:-$(subro_default_sock)}"
CWD="$(pwd)"

echo "== subro doctor =="
echo "  version: $(subro_version "$ROOT")"
echo "  (broker is on-demand — doctor starts it when needed, same as ./bin/agent)"
echo

echo "1) Broker daemon"
if ! "$ROOT/bin/broker-daemon" status >/dev/null 2>&1; then
  warn "broker not running — starting now"
  subro_ensure_broker "$ROOT"
fi
if "$ROOT/bin/broker-daemon" status >/dev/null 2>&1; then
  ok "broker running"
else
  bad "broker failed to start (see .broker/log.txt)"
fi

echo "2) Socket"
if [[ -S "$SOCK" ]]; then
  ok "socket exists: $SOCK"
else
  bad "socket missing after start (stale file removed on start; check .broker/log.txt)"
fi

echo "3) Broker env"
BROKER_ENV_FILE="${BROKER_ENV_FILE:-${HOME}/.config/agent-broker/env}"
if [[ -f "$BROKER_ENV_FILE" ]]; then
  ok "env file: $BROKER_ENV_FILE"
else
  warn "no env file (run ./bin/setup)"
fi
roots_check="$(subro_validate_broker_roots warn "$CWD" 2>&1)" || true
if [[ -n "$roots_check" ]]; then
  echo "$roots_check" | sed 's/^/  /'
else
  ok "BROKER_ALLOWED_ROOTS OK for $CWD"
fi
if [[ -n "${BROKER_SOCKET_TOKEN:-}" ]]; then
  ok "BROKER_SOCKET_TOKEN is set"
else
  warn "BROKER_SOCKET_TOKEN unset (optional; run ./bin/setup)"
fi

echo "4) Registered tools (broker log)"
if [[ -f "$ROOT/.broker/log.txt" ]]; then
  if grep -q "tools:" "$ROOT/.broker/log.txt" 2>/dev/null; then
    grep "tools:" "$ROOT/.broker/log.txt" | tail -1 | sed 's/^/  /'
  else
    warn "restart broker to refresh tool list in logs"
  fi
fi

echo "5) Sandbox backend"
SANDBOX_BACKEND="$(subro_sandbox_backend)"
if [[ "$SANDBOX_BACKEND" == "cplt" ]]; then
  ok "SUBRO_SANDBOX=cplt (navikt/cplt — optional MIT dependency)"
  if subro_cplt_available; then
    ok "cplt at $(subro_cplt_bin) ($(cplt --version 2>/dev/null || echo unknown))"
  else
    warn "cplt not on PATH (agent-run falls back to native; brew install navikt/tap/cplt)"
  fi
else
  ok "SUBRO_SANDBOX=native (Seatbelt / Landlock)"
  if subro_cplt_available; then
    warn "cplt installed but unused (set SUBRO_SANDBOX=cplt in broker env to enable)"
  fi
fi

echo "6) Kernel sandbox (native backend)"
case "$(uname -s)" in
  Darwin)
    if command -v sandbox-exec >/dev/null 2>&1; then
      ok "sandbox-exec available (Seatbelt)"
    else
      warn "sandbox-exec not found (SUBRO_NO_SANDBOX=1 fallback)"
    fi
    ;;
  Linux)
    landlock_line="$(subro_landlock_status "$ROOT" 2>&1)" || landlock_rc=$?
    landlock_rc="${landlock_rc:-0}"
    if [[ "$landlock_rc" -eq 0 ]]; then
      ok "Landlock: $landlock_line"
    else
      warn "Landlock: $landlock_line"
    fi
    ;;
  *)
    warn "unsupported OS for kernel sandbox: $(uname -s)"
    ;;
esac

echo "7) Host broker ping (outside sandbox)"
if [[ -S "$SOCK" ]]; then
  export BROKER_SOCK="$SOCK"
  if "$ROOT/interceptors/entur-departures" --help >/dev/null 2>&1; then
    ok "broker responded to entur-departures --help"
  else
    bad "broker call failed (check BROKER_ALLOWED_ROOTS includes $CWD)"
  fi
else
  bad "skipped (no socket)"
fi

echo "8) In-sandbox broker UDS (entur-departures --help)"
if "$ROOT/bin/agent-run" bash -lc 'entur-departures --help >/dev/null' 2>/dev/null; then
  ok "sandbox can reach broker via UDS"
elif [[ "$(subro_sandbox_backend)" == "cplt" ]]; then
  bad "broker UDS failed under SUBRO_SANDBOX=cplt (see docs/cplt.md — socket policy)"
else
  bad "in-sandbox broker call failed (broker down, token mismatch, or Seatbelt socket deny)"
fi

echo "9) In-sandbox entur-departures smoke"
if "$ROOT/bin/agent-run" bash -lc 'entur-departures jernbanetorget 1 >/dev/null' 2>/dev/null; then
  ok "sandbox entur-departures returned data"
elif [[ "$(subro_sandbox_backend)" == "cplt" ]]; then
  bad "entur smoke failed under SUBRO_SANDBOX=cplt (broker UDS policy? try native or see docs/cplt.md)"
else
  warn "entur smoke call failed (network/API or broker policy; --help test above is the critical check)"
fi

echo "10) Sandbox shell smoke"
if "$ROOT/bin/agent-run" bash -lc 'echo sandbox-ok' >/dev/null 2>&1; then
  ok "agent-run sandbox executes"
else
  bad "agent-run failed (try SUBRO_NO_SANDBOX=1 for diagnosis)"
fi

echo "11) Interceptors on PATH"
if "$ROOT/bin/agent-run" bash -lc 'command -v mvn | grep -q interceptors'; then
  ok "mvn resolves to interceptor"
else
  warn "mvn interceptor not first in PATH"
fi

echo "12) pi harness (optional)"
if command -v pi >/dev/null 2>&1; then
  if subro_prepare_pi_shims "$CWD" >/dev/null 2>&1; then
    ok "pi + node shims ready in .agent-bin/"
  else
    warn "pi found but shim setup failed"
  fi
  if "$ROOT/bin/agent-run" pi --help >/dev/null 2>&1; then
    ok "sandbox pi --help (no LLM)"
  else
    warn "sandbox pi --help failed"
  fi
  if "$ROOT/bin/agent-run" pi list >/dev/null 2>&1; then
    ok "sandbox pi list (no LLM)"
  else
    warn "sandbox pi list failed"
  fi
else
  warn "pi not on PATH (optional; npm i -g @earendil-works/pi-coding-agent)"
fi

echo "13) opencode harness (optional)"
if command -v opencode >/dev/null 2>&1; then
  if subro_prepare_opencode_shims "$CWD" >/dev/null 2>&1; then
    ok "opencode shims ready in .agent-bin/"
  else
    warn "opencode found but shim setup failed"
  fi
else
  warn "opencode not on PATH (optional; https://opencode.ai/docs/config/)"
fi

echo
if [[ "$FAIL" -eq 0 ]]; then
  echo "All checks passed."
  exit 0
fi
echo "Some checks failed."
exit 1
