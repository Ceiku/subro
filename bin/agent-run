#!/usr/bin/env bash
set -euo pipefail

ROOT="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
# shellcheck source=bin/_lib.sh
source "${ROOT}/bin/_lib.sh"

if [[ $# -lt 1 ]]; then
  echo "Usage: $0 <agent-command> [args...]" >&2
  exit 2
fi

default_sock() {
  local uname_s
  uname_s="$(uname -s)"
  case "$uname_s" in
    Darwin)
      echo "${HOME}/Library/Application Support/agent-broker/agent-broker.sock"
      ;;
    Linux)
      local rt
      rt="${XDG_RUNTIME_DIR:-/tmp}"
      echo "${rt}/agent-broker/agent-broker.sock"
      ;;
    *)
      echo "/tmp/agent-broker/agent-broker.sock"
      ;;
  esac
}

SOCK="${BROKER_SOCK:-$(default_sock)}"
WORKDIR="$(pwd)"
AGENT_HOME="${WORKDIR}/.agent-home"
mkdir -p "$AGENT_HOME"

INTERCEPTORS_DIR="${ROOT}/interceptors"

AGENT_BIN_DIR="${WORKDIR}/.agent-bin"
mkdir -p "$AGENT_BIN_DIR"

SANDBOX_PATH="${AGENT_BIN_DIR}:${INTERCEPTORS_DIR}:/usr/bin:/bin:/usr/sbin:/sbin"

load_broker_env() {
  local env_file="${BROKER_ENV_FILE:-${HOME}/.config/agent-broker/env}"
  if [[ -f "$env_file" ]]; then
    set -a
    # shellcheck disable=SC1090
    source "$env_file"
    set +a
  fi
}

load_broker_env

sandbox_env() {
  env -i \
    PATH="$SANDBOX_PATH" \
    HOME="$AGENT_HOME" \
    TMPDIR="/tmp" \
    BROKER_SOCK="$SOCK" \
    SUBRO_ROOT="$ROOT" \
    ${BROKER_SOCKET_TOKEN:+BROKER_SOCKET_TOKEN="$BROKER_SOCKET_TOKEN"} \
    ${PI_CODING_AGENT_DIR:+PI_CODING_AGENT_DIR="$PI_CODING_AGENT_DIR"} \
    ${PI_CODING_AGENT_SESSION_DIR:+PI_CODING_AGENT_SESSION_DIR="$PI_CODING_AGENT_SESSION_DIR"} \
    ${OPENCODE_CONFIG_DIR:+OPENCODE_CONFIG_DIR="$OPENCODE_CONFIG_DIR"} \
    ${OPENCODE_DATA_DIR:+OPENCODE_DATA_DIR="$OPENCODE_DATA_DIR"} \
    ${OPENCODE_CACHE_DIR:+OPENCODE_CACHE_DIR="$OPENCODE_CACHE_DIR"} \
    ${OPENCODE_STATE_DIR:+OPENCODE_STATE_DIR="$OPENCODE_STATE_DIR"} \
    ${OPENCODE_CONFIG:+OPENCODE_CONFIG="$OPENCODE_CONFIG"} \
    "$@"
}

run_unsandboxed() {
  sandbox_env "$@"
  exit $?
}

run_macos_sandbox() {
  local profile_file macos_user_temp
  profile_file="$(mktemp "${TMPDIR:-/tmp}/subro-seatbelt.XXXXXX")"
  macos_user_temp=""
  if command -v getconf >/dev/null 2>&1; then
    macos_user_temp="$(getconf DARWIN_USER_TEMP_DIR 2>/dev/null || true)"
  fi
  # Seatbelt: broad read + scoped write + explicit denies (invalid ops like
  # process* / file-read-data cause sandbox-exec to abort on macOS).
  cat >"$profile_file" <<EOF
(version 1)
(deny default)
(allow process-exec)
(allow process-fork)
(allow signal)
(allow sysctl-read)
(allow mach-lookup)
; Read allowlist tightening (P2.3): global read + explicit denies below.
; Narrow subpath-only reads break bash/python on macOS in practice.
(allow file-read*)
(allow file-write* (subpath "/tmp"))
(allow file-write* (subpath "/private/var/folders"))
(allow file-write* (subpath "/dev"))
(allow file-write* (subpath "${WORKDIR}"))
(allow file-write* (literal "${SOCK}"))
(allow network-outbound)
(deny file-read* (literal "${WORKDIR}/.env"))
(deny file-read* (literal "${WORKDIR}/.env.local"))
(deny file-read* (literal "${WORKDIR}/.env.development"))
(deny file-read* (literal "${WORKDIR}/.env.test"))
(deny file-read* (literal "${WORKDIR}/.env.production"))
(deny file-read* (literal "${WORKDIR}/.npmrc"))
(deny file-read* (literal "${WORKDIR}/.pypirc"))
(deny file-read* (literal "${WORKDIR}/.netrc"))
(deny file-read* file-write* (subpath "${HOME}/.ssh"))
(deny file-read* file-write* (subpath "${HOME}/.m2"))
(deny file-read* (literal "${HOME}/.npmrc"))
(deny file-read* (subpath "${HOME}/.config/npm"))
(deny file-read* (subpath "${HOME}/.config/pnpm"))
(deny file-read* (subpath "${HOME}/.pnpm-store"))
(deny file-read* (literal "${HOME}/.pypirc"))
(deny file-read* (subpath "${HOME}/.config/pip"))
(deny file-read* (subpath "${HOME}/.pip"))
(deny file-read* (literal "${HOME}/.netrc"))
(deny file-read* (literal "${HOME}/.bashrc"))
(deny file-read* (literal "${HOME}/.bash_profile"))
(deny file-read* (literal "${HOME}/.profile"))
(deny file-read* (literal "${HOME}/.zshrc"))
(deny file-read* (literal "${HOME}/.zprofile"))
(deny file-read* (literal "${HOME}/.zshenv"))
EOF
  if [[ -n "$macos_user_temp" ]]; then
    printf '\n(allow file-write* (subpath "%s"))\n' "$macos_user_temp" >>"$profile_file"
  fi
  if [[ "${1:-}" == "pi" || "${1:-}" == "opencode" ]]; then
    subro_append_seatbelt_harness_writes "${1}" "$profile_file"
  fi

  sandbox_env sandbox-exec -f "$profile_file" -- "$@"
  rc=$?
  rm -f "$profile_file"
  if [[ $rc -ne 0 ]]; then
    echo "sandbox-exec failed (exit $rc). You may need to run from a normal host terminal, or set SUBRO_NO_SANDBOX=1 to run without kernel sandboxing." >&2
  fi
  exit "$rc"
}

run_linux_landlock() {
  local harness="${1:-}"
  local wp landlock_bin
  local -a landlock_rw=(
    --allow-read-write "$WORKDIR"
    --allow-read-write "$INTERCEPTORS_DIR"
    --allow-read-write "$AGENT_BIN_DIR"
    --allow-read-write "$(dirname "$SOCK")"
  )

  landlock_bin="$(subro_landlock_restrict_bin "$ROOT")"
  if [[ -z "$landlock_bin" ]]; then
    echo "landlock-restrict not found; running without kernel sandbox." >&2
    echo "  Build: ./bin/build-landlock-restrict" >&2
    run_unsandboxed "$@"
  fi

  while IFS= read -r wp; do
    [[ -n "$wp" ]] || continue
    landlock_rw+=(--allow-read-write "$wp")
  done < <(subro_harness_write_paths "$harness")

  # landlock-restrict policy:
  # - allow full access to current workdir + socket + harness host dirs
  # - deny sensitive host dirs (best-effort, depends on landlock-restrict implementation)
  sandbox_env "$landlock_bin" \
      "${landlock_rw[@]}" \
      --deny-read-write "$WORKDIR/.env" \
      --deny-read-write "$WORKDIR/.env.local" \
      --deny-read-write "$WORKDIR/.env.development" \
      --deny-read-write "$WORKDIR/.env.test" \
      --deny-read-write "$WORKDIR/.env.production" \
      --deny-read-write "$WORKDIR/.npmrc" \
      --deny-read-write "$WORKDIR/.pypirc" \
      --deny-read-write "$WORKDIR/.netrc" \
      --deny-read-write "$HOME/.ssh" \
      --deny-read-write "$HOME/.m2" \
      --deny-read-write "$HOME/.npmrc" \
      --deny-read-write "$HOME/.config/npm" \
      --deny-read-write "$HOME/.config/pnpm" \
      --deny-read-write "$HOME/.pnpm-store" \
      --deny-read-write "$HOME/.pypirc" \
      --deny-read-write "$HOME/.config/pip" \
      --deny-read-write "$HOME/.pip" \
      --deny-read-write "$HOME/.netrc" \
      -- "$@"
  rc=$?
  if [[ $rc -ne 0 ]]; then
    echo "landlock-restrict failed (exit $rc). You may need to install/configure Landlock, or set SUBRO_NO_SANDBOX=1 to run without kernel sandboxing." >&2
  fi
  exit "$rc"
}

if [[ "${1:-}" == "pi" ]]; then
  subro_prepare_pi_shims "$WORKDIR" || exit 1
  subro_export_pi_harness_env "$HOME"
fi

if [[ "${1:-}" == "opencode" ]]; then
  subro_prepare_opencode_shims "$WORKDIR" || exit 1
  subro_export_opencode_harness_env "$HOME"
fi

SANDBOX_BACKEND="$(subro_sandbox_backend)"

if [[ "${SUBRO_NO_SANDBOX:-}" != "1" && "$SANDBOX_BACKEND" == "cplt" ]]; then
  if subro_cplt_available; then
    subro_run_cplt_sandbox "$SANDBOX_PATH" "$SOCK" "$ROOT" "$@"
    exit $?
  fi
  echo "SUBRO_SANDBOX=cplt but cplt not found; falling back to native sandbox." >&2
  echo "  Install: brew install navikt/tap/cplt  (see docs/cplt.md)" >&2
fi

uname_s="$(uname -s)"
case "$uname_s" in
  Darwin)
    if [[ "${SUBRO_NO_SANDBOX:-}" == "1" ]]; then
      run_unsandboxed "$@"
    fi
    if command -v sandbox-exec >/dev/null 2>&1; then
      run_macos_sandbox "$@"
    fi
    echo "sandbox-exec not found; running without kernel sandbox." >&2
    run_unsandboxed "$@"
    ;;
  Linux)
    if [[ "${SUBRO_NO_SANDBOX:-}" == "1" ]]; then
      run_unsandboxed "$@"
    fi
    run_linux_landlock "$@"
    ;;
  *)
    echo "Unsupported OS: $uname_s (running without kernel sandbox)" >&2
    run_unsandboxed "$@"
    ;;
esac

