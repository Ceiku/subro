#!/usr/bin/env bash
set -euo pipefail
DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"

has_placeholder=0
for a in "$@"; do
  if [[ "$a" == *"X-PROD-KEY"* ]]; then
    has_placeholder=1
    break
  fi
done

if [[ "$has_placeholder" -eq 0 ]]; then
  exec /usr/bin/curl "$@"
fi

exec env TMPDIR="${TMPDIR:-/tmp}" PYTHONDONTWRITEBYTECODE=1 \
  python3 "${DIR}/_broker_call.py" curl "$@"
